# DevSocial Environment Configuration

# GitHub OAuth (required) — https://github.com/settings/developers
GITHUB_CLIENT_ID=your_client_id_here
GITHUB_CLIENT_SECRET=your_client_secret_here

# Base URL for OAuth callbacks (default: http://localhost:8888)
BASE_URL=http://localhost:8888

# PostgreSQL password (default: devsocial)
DB_PASSWORD=devsocial

# App port on host (default: 8888)
APP_PORT=8888

# LiteLLM AI proxy
LITELLM_PORT=4000
LITELLM_MASTER_KEY=sk-devsocial-local

# AI Provider API Keys (set the ones you want to use)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
# For Ollama: no API key needed, just uncomment models in litellm/config.yaml

# MinIO File Storage
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=devsocial
MINIO_ROOT_PASSWORD=devsocial123
MINIO_BUCKET=devsocial

# ChromaDB Vector Store
CHROMA_PORT=8000
